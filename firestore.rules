rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Properties are readable by anyone, writable by authenticated users (creators only)
    match /properties/{propertyId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && resource.data.agentUid == request.auth.uid;
    }
    
    // Market News: readable by anyone (used for Analytics)
    match /market_news/{docId} {
      allow read: if true;
      allow write: if false; // Only backend scraper can write (via Admin SDK)
    }
    // Chats: readable and writable by authenticated users who are participants
    match /chats/{chatId} {
      allow read: if request.auth != null && request.auth.uid in resource.data.participants;
      allow create: if request.auth != null && request.auth.uid in request.resource.data.participants;
      allow update, delete: if request.auth != null && request.auth.uid in resource.data.participants;
      
      match /messages/{messageId} {
        allow read, write: if request.auth != null && 
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
      }
    }
    
    // Alerts (FREE PLAN - aisladas del Broker PRO)
    match /alerts/{alertId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }
    
    // Notifications (FREE PLAN)
    match /notifications/{notificationId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // Users
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ── BROKER PRO (colecciones exclusivas, separadas del plan gratuito) ──

    // broker_alerts: Motor de alertas exclusivo del Broker PRO
    match /broker_alerts/{alertId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // broker_notifications: Notificaciones del motor de oportunidades
    match /broker_notifications/{notifId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // broker_leads: Mercado de compradores del Broker PRO
    match /broker_leads/{leadId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
